# .coderev.toml.example — CodeRev project configuration
# Copy to .coderev.toml and uncomment the settings you want.
# CLI flags always override these settings.
# Docs: see README.md § Configuration

[review]
# Fail CI when findings at or above this severity are found
# Options: critical | high | medium | low | none (default: none)
# fail_on = "high"

# Minimum confidence score to include a finding (0.0–1.0)
# min_confidence = 0.7

# Default output format: rich | json | markdown | sarif
# format = "rich"

# Groq model (must be available on Groq)
# model = "moonshotai/kimi-k2-instruct"

# Skip prompt cache
# no_cache = false

# Maximum diff lines before truncation
# max_diff_lines = 5000

[agents]
# Which specialist agents to run
# enabled = ["security", "performance", "correctness"]

[exclude]
# Glob patterns to exclude from review
# paths = ["vendor/", "generated/", "*.min.js"]

# Categories to suppress
# categories = []

# Severities to suppress (e.g. suppress info-level noise)
# severities = []

[eval]
# Thresholds for coderev eval pass/fail
# recall_threshold = 0.80
# precision_threshold = 0.70
