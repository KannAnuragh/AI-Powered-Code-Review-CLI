# CodeRev Environment Configuration
# Copy this file to .env and fill in your values

# Required: Your Groq API key
# Get one at: https://console.groq.com/
GROQ_API_KEY=your_api_key_here

# Optional: Default model to use (defaults to kimi-k2-0528)
# CODEREV_MODEL=kimi-k2-0528

# Optional: Default fail-on severity for CI (defaults to critical)
# CODEREV_FAIL_ON=critical

# Optional: Default minimum confidence threshold (defaults to 0.0)
# CODEREV_MIN_CONFIDENCE=0.0